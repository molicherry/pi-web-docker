# ── pi-web .env ────────────────────────────────────────────────────
# Copy this file to .env and edit.

# ─── Version ────────────────────────────────────────────────────────
PI_WEB_VERSION=main            # agegr/pi-web branch or tag, e.g. v0.7.16

# ─── Container ──────────────────────────────────────────────────────
CONTAINER_NAME=pi-web
PI_WEB_PORT=30141
PUID=1000                      # run: id -u
PGID=1000                      # run: id -g
PI_WEB_MEM_LIMIT=2g
PI_WEB_CPUS=2.0

# ─── Volumes ────────────────────────────────────────────────────────
PI_AGENT_DIR=~/.pi/agent       # pi config, sessions, models, auth
PI_WORKSPACE_DIR=~/pi-workspace  # project dir mounted to /workspace
PI_NPM_GLOBAL_DIR=~/.pi/npm-global  # npm global packages (persistent)

# ─── API Keys (at least one required) ───────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
